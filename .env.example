# PostgreSQL Database Configuration
# Copy this file to .env and update with your credentials

DB_NAME=german_vocabulary
DB_USER=local_db_user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-hex-string

# LLM — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Set to true to skip the LLM and return random mock replies (useful during development)
MOCK_LLM=false
